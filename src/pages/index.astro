---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Mv from "../components/Mv.astro";
import Works from "../components/Works.astro";
import ProcessQuality from "../components/ProcessQuality.astro";
import Skills from "../components/Skills.astro";
import Career from "../components/Career.astro";
import Profile from "../components/Profile.astro";
import "../assets/scss/style.scss";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" as="style">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap"
    />
    <title>あべゆうたのポートフォリオ | Webコーダー</title>
  </head>
  <body>
    <Header />
    <main class="l-container">
      <Mv />
      <Works />
      <ProcessQuality />
      <Skills />
      <Career />
      <Profile />
    </main>
    <Footer />
    <script>
      import '../assets/js/main.js';
    </script>
  </body>
</html>
